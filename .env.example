# ── Server-only secrets (set these on Vercel) ──

# Google Gemini API Key (for AI translation feature, optional)
GEMINI_API_KEY=

# ── Client-side variables (NEXT_PUBLIC_ prefix, embedded at build time) ──

# Production URL (used for OG/meta tags)
NEXT_PUBLIC_SITE_URL=https://a-azadi.blog

# Sentry DSN (optional, for error tracking)
NEXT_PUBLIC_SENTRY_DSN=

# Google Analytics Measurement ID (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
